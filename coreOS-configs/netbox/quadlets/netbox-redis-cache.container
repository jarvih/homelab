[Unit]
Description=NetBox Redis Cache
# Stay inert until the operator creates the real env file (copy redis-cache.env.example
# → redis-cache.env and fill in the password). Avoids starting with a placeholder.
ConditionPathExists=%h/netbox/env/redis-cache.env

[Container]
ContainerName=netbox-redis-cache
Image=docker.io/valkey/valkey:9.0-alpine
Pod=netbox.pod
EnvironmentFile=%h/netbox/env/redis-cache.env
Volume=netbox-redis-cache-data:/data
Exec=sh -c 'valkey-server --port 6380 --requirepass "$REDIS_PASSWORD"'

[Service]
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
