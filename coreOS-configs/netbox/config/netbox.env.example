# Copy to $HOME/netbox/env/netbox.env on the netbox host and fill in real values.
# Read via EnvironmentFile= by the netbox and netbox-worker containers.
#
# DB_USER, REDIS_CACHE_PORT and CORS_ORIGIN_ALLOW_ALL are set in the quadlets,
# so they are intentionally NOT repeated here.

# Django secret key, 50+ random chars. Generate with:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=changeme-generate-a-long-random-string

# PostgreSQL (in-pod, on localhost). DB_PASSWORD must match POSTGRES_PASSWORD
# in postgres.env.
DB_HOST=localhost
DB_NAME=netbox
DB_PASSWORD=changeme-db-password
DB_PORT=5432

# Redis task queue. REDIS_PASSWORD must match redis.env.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme-redis-password
REDIS_DATABASE=0

# Redis cache. REDIS_CACHE_PASSWORD must match REDIS_PASSWORD in redis-cache.env.
# (REDIS_CACHE_PORT=6380 is set in the quadlet.)
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PASSWORD=changeme-redis-cache-password
REDIS_CACHE_DATABASE=1

# The previous secret-based setup also injected an "api_token_pepper_1" value.
# If your configuration.py references an API token pepper, add the matching
# variable here, e.g.:
#   API_TOKEN_PEPPER=changeme-pepper
